# AI Vibe Toolkit — Environment Variables
# Copy sang .env và điền giá trị thật
# cp deploy/env.example .env

# ============================================================
# GITHUB
# ============================================================
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=tano2026/AI-Vibe-Toolkit

# ============================================================
# AI APIs
# ============================================================
ANTHROPIC_API_KEY=sk-ant-your_key_here
OPENAI_API_KEY=sk-your_key_here  # optional

# ============================================================
# SEARCH & CRAWL
# ============================================================
BRAVE_API_KEY=your_brave_key
FIRECRAWL_API_KEY=your_firecrawl_key

# ============================================================
# MESSAGING (cho OpenClaw)
# ============================================================
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ============================================================
# MARKETING MCPs (optional)
# ============================================================
META_ACCESS_TOKEN=your_meta_token
META_PAGE_ID=your_page_id
HUBSPOT_ACCESS_TOKEN=pat-your_hubspot_token
BUFFER_ACCESS_TOKEN=your_buffer_token

# ============================================================
# ACCOUNTING MCPs (optional)
# ============================================================
JAZ_API_KEY=your_jaz_key
XERO_CLIENT_ID=your_xero_id
XERO_CLIENT_SECRET=your_xero_secret

# ============================================================
# AUTOMATION
# ============================================================
N8N_HOST=http://localhost:5678
N8N_API_KEY=your_n8n_key

# ============================================================
# VPS
# ============================================================
VPS_IP=your_vps_ip
VPS_USER=root
NODE_ENV=production
PORT=3000
